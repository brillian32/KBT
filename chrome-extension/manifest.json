{
  "manifest_version": 3,
  "name": "Knowledge Base Tools",
  "version": "1.0.0",
  "description": "一键保存网页内容到 Obsidian 知识库",
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
